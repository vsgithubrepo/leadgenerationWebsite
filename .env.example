# ─────────────────────────────────────────────────────────────────
# .env.local  —  NEVER commit this file to git!
# Copy this as ".env.local" in your project root
# ─────────────────────────────────────────────────────────────────

# ── Clerk Authentication (FREE) ───────────────────────────────────
# 1. Go to https://clerk.com  →  Sign up free
# 2. Create new application  →  name it "LeadEngine"
# 3. Enable "Google" as sign-in provider
# 4. Copy your Publishable Key below
REACT_APP_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# ── Your Company Email Domain ─────────────────────────────────────
# Only emails from this domain can sign in.
# Example: if your company email is john@acme.com, set this to acme.com
REACT_APP_ALLOWED_DOMAIN=yourcompany.com

# ── App Config ────────────────────────────────────────────────────
REACT_APP_COMPANY_NAME=Your Company Name
